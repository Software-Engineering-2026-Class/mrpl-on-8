# Environment variables for Agentic AI Framework Generator

# Gemini API Key for Language Model operations
GEMINI_API_KEY=your_gemini_api_key_here

# OpenAI API Key (if you wish to use OpenAI models via LangChain/CrewAI)
OPENAI_API_KEY=your_openai_api_key_here

# Model to be used
OPENAI_MODEL_NAME=gemini/gemini-3.1-flash-lite
